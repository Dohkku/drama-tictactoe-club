# Match 01 — Akira intro (after prologue)
# Short setup before the first game.

@scene match_01_intro

[board_disable]

[pose akira arms_crossed]
[look_at akira player]

akira "smirk" -> player: Reglas simples. Tres en raya. Sin trucos.
akira "confident": Yo voy segundo. Te doy esa ventaja.

[pose akira leaning_forward]
[shake 0.5 0.2]
akira "intense" -> player: ¡No la desperdicies!

player "determined": No lo haré.

[pose akira idle]
[board_enable]
@end
