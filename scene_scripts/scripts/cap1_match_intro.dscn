@scene cap1_match_intro

[board_disable]

[enter ryu right right]
[look_at ryu player]
[pose ryu arms_crossed]

ryu "neutral" -> player: Tres en raya. 3x3. Sin adornos.

[pose ryu idle]
ryu "cold" -> player: Muestra lo que tienes.

player "determined": (No voy a perder en mi primera partida.)

[board_enable]
@end
