[gd_resource type="Resource" script_class="ProjectData" format=3]

[ext_resource type="Resource" path="res://characters/data/ryu.tres" id="1_chr_r"]
[ext_resource type="Resource" path="res://characters/data/sora.tres" id="2_chr_s"]
[ext_resource type="Resource" path="res://characters/data/player.tres" id="3_chr_p"]
[ext_resource type="Script" path="res://data/tournament_event.gd" id="4_te"]
[ext_resource type="Script" path="res://match_system/match_config.gd" id="5_mc"]
[ext_resource type="Script" path="res://data/project_data.gd" id="6_pd"]
[ext_resource type="Script" path="res://data/board_config.gd" id="7_bc"]
[ext_resource type="Script" path="res://systems/board_logic/game_rules.gd" id="8_gr"]

[sub_resource type="Resource" id="rules_std"]
script = ExtResource("8_gr")
board_size = 3
win_length = 3

[sub_resource type="Resource" id="board_cfg"]
script = ExtResource("7_bc")
game_rules = SubResource("rules_std")
max_board_size = 420
cell_color_empty = Color(0.88, 0.85, 0.78, 1)
cell_color_alt = Color(0.22, 0.25, 0.3, 1)
checkerboard_enabled = true
cell_color_hover = Color(0.75, 0.72, 0.65, 1)
cell_line_color = Color(0.4, 0.35, 0.3, 1)
cell_line_width = 1.5
board_border_enabled = true
board_border_color = Color(0.45, 0.35, 0.25, 1)
board_border_width = 10.0
hand_area_height = 50
piece_cell_ratio = 0.85
default_player_color = Color(0.2, 0.5, 1, 1)
default_opponent_color = Color(0.9, 0.2, 0.2, 1)
board_bg_color = Color(0.3, 0.28, 0.24, 1)

[sub_resource type="Resource" id="evt0"]
script = ExtResource("4_te")
event_type = "cutscene"
event_name = "Cap 1: La Invitacion"
cutscene_script_path = "res://scene_scripts/scripts/cap1_intro.dscn"
order_index = 0

[sub_resource type="Resource" id="mc1"]
script = ExtResource("5_mc")
match_id = "cap1_ryu"
opponent_id = "ryu"
ai_difficulty = 0.3
intro_script = "res://scene_scripts/scripts/cap1_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/cap1_reactions.dscn"
player_style = "slam"
opponent_style = "gentle"

[sub_resource type="Resource" id="evt1"]
script = ExtResource("4_te")
event_type = "match"
event_name = "vs Ryu"
match_config = SubResource("mc1")
order_index = 1

[sub_resource type="Resource" id="evt2"]
script = ExtResource("4_te")
event_type = "cutscene"
event_name = "Cap 2: El Estilo de Sora"
cutscene_script_path = "res://scene_scripts/scripts/cap2_intro.dscn"
order_index = 2

[sub_resource type="Resource" id="mc2"]
script = ExtResource("5_mc")
match_id = "cap2_sora"
opponent_id = "sora"
ai_difficulty = 0.4
intro_script = "res://scene_scripts/scripts/cap2_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/cap2_reactions.dscn"
player_style = "slam"
opponent_style = "dramatic"

[sub_resource type="Resource" id="evt3"]
script = ExtResource("4_te")
event_type = "match"
event_name = "vs Sora"
match_config = SubResource("mc2")
order_index = 3

[sub_resource type="Resource" id="evt4"]
script = ExtResource("4_te")
event_type = "cutscene"
event_name = "Cap 3: El Ultimo Tablero"
cutscene_script_path = "res://scene_scripts/scripts/cap3_intro.dscn"
order_index = 4

[sub_resource type="Resource" id="sim_ryu"]
script = ExtResource("5_mc")
match_id = "sim_ryu"
opponent_id = "ryu"
ai_difficulty = 0.45
intro_script = "res://scene_scripts/scripts/cap3_sim_ryu_intro.dscn"
reactions_script = "res://scene_scripts/scripts/cap1_reactions.dscn"
player_style = "slam"
opponent_style = "gentle"
turns_per_visit = 2

[sub_resource type="Resource" id="sim_sora"]
script = ExtResource("5_mc")
match_id = "sim_sora"
opponent_id = "sora"
ai_difficulty = 0.4
intro_script = "res://scene_scripts/scripts/cap3_sim_sora_intro.dscn"
reactions_script = "res://scene_scripts/scripts/cap2_reactions.dscn"
player_style = "slam"
opponent_style = "dramatic"
turns_per_visit = 2

[sub_resource type="Resource" id="evt5"]
script = ExtResource("4_te")
event_type = "simultaneous"
event_name = "Ronda Final"
simultaneous_configs = Array[Resource]([SubResource("sim_ryu"), SubResource("sim_sora")])
order_index = 5

[sub_resource type="Resource" id="evt6"]
script = ExtResource("4_te")
event_type = "cutscene"
event_name = "Finale"
cutscene_script_path = "res://scene_scripts/scripts/finale.dscn"
order_index = 6

[resource]
script = ExtResource("6_pd")
project_name = "El Ultimo Tablero"
characters = Array[Resource]([ExtResource("1_chr_r"), ExtResource("2_chr_s"), ExtResource("3_chr_p")])
events = Array[Resource]([SubResource("evt0"), SubResource("evt1"), SubResource("evt2"), SubResource("evt3"), SubResource("evt4"), SubResource("evt5"), SubResource("evt6")])
board_config = SubResource("board_cfg")
