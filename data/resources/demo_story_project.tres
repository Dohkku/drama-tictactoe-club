checkerboard_enabled = true
cell_color_hover = Color(0.75, 0.72, 0.65, 1)
cell_line_color = Color(0.5, 0.4, 0.35, 1)
cell_line_width = 1.0
board_border_enabled = true
board_border_color = Color(0.5, 0.3, 0.2, 1)
board_border_width = 8.0
hand_area_height = 60
piece_cell_ratio = 0.8
default_player_color = Color(0.9, 0.3, 0.2, 1)
default_opponent_color = Color(0.9, 0.7, 0.1, 1)
board_bg_color = Color(0.25, 0.22, 0.2, 1)

[sub_resource type="Resource" id="mc_akira"]
script = ExtResource("mc")
match_id = "demo_akira"
opponent_id = "akira"
ai_difficulty = 0.6
intro_script = "res://scene_scripts/scripts/demo_ch3_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/demo_ch3_reactions.dscn"
