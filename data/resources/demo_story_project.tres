; ══════════════════════════════════════════════════════════
;  CHAPTER 4: LA ESTRATEGIA
; ══════════════════════════════════════════════════════════

; ── Event 6: Strategy scene — Mei's analysis (cinematic) ──
[sub_resource type="Resource" id="evt_ch4_strategy"]
script = ExtResource("te")
event_type = "cutscene"
event_name = "Cap 4: La Estrategia"
cutscene_script_path = "res://scene_scripts/scripts/demo_ch4_strategy.dscn"
order_index = 6

; ── Event 7: Match vs Mei (3x3 rotation, max 3 pieces, no draw, nervous/gentle, smoke, square/diamond) ──
[sub_resource type="Resource" id="rules_rotation"]
script = ExtResource("gr")
board_size = 3
win_length = 3
max_pieces_per_player = 3
overflow_mode = "rotate"
allow_draw = false

[sub_resource type="Resource" id="board_rotation"]
script = ExtResource("bc")
game_rules = SubResource("rules_rotation")
max_board_size = 380
cell_color_empty = Color(0.82, 0.78, 0.88, 1)
cell_color_alt = Color(0.3, 0.28, 0.35, 1)
checkerboard_enabled = false
cell_color_hover = Color(0.72, 0.68, 0.78, 1)
cell_line_color = Color(0.45, 0.4, 0.5, 1)
cell_line_width = 2.0
board_border_enabled = true
board_border_color = Color(0.5, 0.35, 0.6, 1)
board_border_width = 8.0
hand_area_height = 80
piece_cell_ratio = 0.8
default_player_color = Color(0.3, 0.7, 0.9, 1)
default_opponent_color = Color(0.7, 0.3, 0.9, 1)
board_bg_color = Color(0.2, 0.18, 0.25, 1)

[sub_resource type="Resource" id="mc_mei"]
script = ExtResource("mc")
match_id = "demo_mei"
opponent_id = "mei"
ai_difficulty = 0.75
intro_script = "res://scene_scripts/scripts/demo_ch4_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/demo_ch4_reactions.dscn"
player_style = "nervous"
opponent_style = "gentle"
player_effect_name = "smoke"
opponent_effect_name = "none"
placement_offset = 0.05
player_piece_design = "square"
opponent_piece_design = "diamond"
board_config = SubResource("board_rotation")

[sub_resource type="Resource" id="evt_ch4_match"]
script = ExtResource("te")
event_type = "match"
event_name = "vs Mei"
match_config = SubResource("mc_mei")
order_index = 7

