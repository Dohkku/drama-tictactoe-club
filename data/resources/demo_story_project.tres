; ══════════════════════════════════════════════════════════
;  ROOT RESOURCE
; ══════════════════════════════════════════════════════════

[resource]
script = ExtResource("pd")
project_name = "Demo Story — 5 Capitulos"
characters = Array[Resource]([ExtResource("chr_sora"), ExtResource("chr_ryu"), ExtResource("chr_akira"), ExtResource("chr_mei"), ExtResource("chr_player")])
events = Array[Resource]([SubResource("evt_ch1_prologue"), SubResource("evt_ch1_match"), SubResource("evt_ch2_arrival"), SubResource("evt_ch2_match"), SubResource("evt_ch3_tournament"), SubResource("evt_ch3_match"), SubResource("evt_ch4_strategy"), SubResource("evt_ch4_match"), SubResource("evt_ch5_finale"), SubResource("evt_ch5_match")])
board_config = SubResource("board_cfg")
