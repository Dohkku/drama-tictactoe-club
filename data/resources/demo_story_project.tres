[gd_resource type="Resource" script_class="ProjectData" format=3]

[ext_resource type="Resource" path="res://characters/data/sora.tres" id="chr_sora"]
[ext_resource type="Resource" path="res://characters/data/ryu.tres" id="chr_ryu"]
[ext_resource type="Resource" path="res://characters/data/akira.tres" id="chr_akira"]
[ext_resource type="Resource" path="res://characters/data/mei.tres" id="chr_mei"]
[ext_resource type="Resource" path="res://characters/data/player.tres" id="chr_player"]
[ext_resource type="Script" path="res://data/tournament_event.gd" id="te"]
[ext_resource type="Script" path="res://match_system/match_config.gd" id="mc"]
[ext_resource type="Script" path="res://data/project_data.gd" id="pd"]
[ext_resource type="Script" path="res://data/board_config.gd" id="bc"]
[ext_resource type="Script" path="res://systems/board_logic/game_rules.gd" id="gr"]

; ══════════════════════════════════════════════════════════
;  DRAMA TIC TAC TOE CLUB — DEMO STORY (5 Chapters)
; ══════════════════════════════════════════════════════════

; ── Default board config (3x3 standard) ──
[sub_resource type="Resource" id="rules_default"]
script = ExtResource("gr")
board_size = 3
win_length = 3

[sub_resource type="Resource" id="board_cfg"]
script = ExtResource("bc")
game_rules = SubResource("rules_default")
max_board_size = 400
cell_color_empty = Color(0.88, 0.85, 0.78, 1)
cell_color_alt = Color(0.22, 0.25, 0.3, 1)
checkerboard_enabled = true
cell_color_hover = Color(0.78, 0.75, 0.68, 1)
cell_line_color = Color(0.4, 0.35, 0.3, 1)
cell_line_width = 1.5
board_border_enabled = true
board_border_color = Color(0.45, 0.35, 0.25, 1)
board_border_width = 10.0
hand_area_height = 80
piece_cell_ratio = 0.85
default_player_color = Color(0.2, 0.5, 1, 1)
default_opponent_color = Color(1.0, 0.4, 0.1, 1)
board_bg_color = Color(0.3, 0.28, 0.24, 1)

; ══════════════════════════════════════════════════════════
;  CHAPTER 1: LA INVITACION
; ══════════════════════════════════════════════════════════

; ── Event 0: Chapter 1 Prologue (cinematic) ──
[sub_resource type="Resource" id="evt_ch1_prologue"]
script = ExtResource("te")
event_type = "cutscene"
event_name = "Cap 1: La Invitacion"
cutscene_script_path = "res://scene_scripts/scripts/demo_ch1_prologue.dscn"
order_index = 0

; ── Board: Sora (warm orange tones) ──
[sub_resource type="Resource" id="rules_sora"]
script = ExtResource("gr")
board_size = 3
win_length = 3

[sub_resource type="Resource" id="board_sora"]
script = ExtResource("bc")
game_rules = SubResource("rules_sora")
max_board_size = 400
cell_color_empty = Color(0.95, 0.88, 0.75, 1)
cell_color_alt = Color(0.35, 0.25, 0.18, 1)
checkerboard_enabled = true
cell_color_hover = Color(1.0, 0.92, 0.78, 1)
cell_line_color = Color(0.7, 0.5, 0.3, 1)
cell_line_width = 1.5
board_border_enabled = true
board_border_color = Color(0.8, 0.5, 0.2, 1)
board_border_width = 10.0
hand_area_height = 80
piece_cell_ratio = 0.85
default_player_color = Color(0.2, 0.5, 1, 1)
default_opponent_color = Color(1.0, 0.5, 0.1, 1)
board_bg_color = Color(0.35, 0.25, 0.15, 1)

; ── Event 1: Match vs Sora (standard 3x3, easy, fire vs sparkle) ──
[sub_resource type="Resource" id="mc_sora"]
script = ExtResource("mc")
match_id = "demo_sora"
opponent_id = "sora"
ai_difficulty = 0.2
intro_script = "res://scene_scripts/scripts/demo_ch1_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/demo_ch1_reactions.dscn"
player_style = "slam"
opponent_style = "gentle"
player_effect_name = "fire"
opponent_effect_name = "sparkle"
player_piece_design = "x"
opponent_piece_design = "o"
board_config = SubResource("board_sora")

[sub_resource type="Resource" id="evt_ch1_match"]
script = ExtResource("te")
event_type = "match"
event_name = "vs Sora"
match_config = SubResource("mc_sora")
order_index = 1

; ══════════════════════════════════════════════════════════
;  CHAPTER 2: LA PRUEBA
; ══════════════════════════════════════════════════════════

; ── Event 2: Ryu arrival (cinematic) ──
[sub_resource type="Resource" id="evt_ch2_arrival"]
script = ExtResource("te")
event_type = "cutscene"
event_name = "Cap 2: La Prueba"
cutscene_script_path = "res://scene_scripts/scripts/demo_ch2_arrival.dscn"
order_index = 2

; ── Board: Ryu (cold dark blue) ──
[sub_resource type="Resource" id="rules_ryu"]
script = ExtResource("gr")
board_size = 3
win_length = 3

[sub_resource type="Resource" id="board_ryu"]
script = ExtResource("bc")
game_rules = SubResource("rules_ryu")
max_board_size = 400
cell_color_empty = Color(0.72, 0.75, 0.85, 1)
cell_color_alt = Color(0.12, 0.15, 0.25, 1)
checkerboard_enabled = true
cell_color_hover = Color(0.65, 0.68, 0.82, 1)
cell_line_color = Color(0.3, 0.3, 0.5, 1)
cell_line_width = 2.0
board_border_enabled = true
board_border_color = Color(0.2, 0.2, 0.45, 1)
board_border_width = 12.0
hand_area_height = 80
piece_cell_ratio = 0.85
default_player_color = Color(0.3, 0.6, 1, 1)
default_opponent_color = Color(0.15, 0.2, 0.5, 1)
board_bg_color = Color(0.08, 0.1, 0.18, 1)

; ── Event 3: Match vs Ryu (3x3, max difficulty, slam/shockwave, diamond) ──
[sub_resource type="Resource" id="mc_ryu"]
script = ExtResource("mc")
match_id = "demo_ryu"
opponent_id = "ryu"
ai_difficulty = 0.9
intro_script = "res://scene_scripts/scripts/demo_ch2_match_intro.dscn"
reactions_script = "res://scene_scripts/scripts/demo_ch2_reactions.dscn"
player_style = "slam"
opponent_style = "slam"
player_effect_name = "none"
opponent_effect_name = "shockwave"
placement_offset = 0.3
player_piece_design = "x"
opponent_piece_design = "diamond"
board_config = SubResource("board_ryu")

[sub_resource type="Resource" id="evt_ch2_match"]
script = ExtResource("te")
event_type = "match"
event_name = "vs Ryu"
match_config = SubResource("mc_ryu")
order_index = 3

; ══════════════════════════════════════════════════════════
;  CHAPTER 3: EL TORNEO
; ══════════════════════════════════════════════════════════

; ── Event 4: Tournament announcement + Akira/Mei intro (cinematic) ──
[sub_resource type="Resource" id="evt_ch3_tournament"]
script = ExtResource("te")
event_type = "cutscene"
event_name = "Cap 3: El Torneo"
cutscene_script_path = "res://scene_scripts/scripts/demo_ch3_tournament.dscn"
